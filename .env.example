# Copy to `.env` at the **repository root** (same folder as `docker-compose.yml`).
# The API loads that file automatically (see `apps/api/app/core/config.py`).
DATABASE_URL=postgresql+psycopg://memory:memory@localhost:5432/memory
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_ALGORITHM=HS256
API_PUBLIC_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000
# Allow any localhost port for the Next dev server (set false in tight production CORS)
CORS_ALLOW_LOCALHOST_ANY_PORT=true
# When true, allows browser Origin matching https://*.vercel.app (Preview + Production). Use with explicit CORS_ORIGINS for your custom domain.
CORS_INCLUDE_VERCEL_APP_HOST=false

# Encryption at rest (dev: 32 url-safe base64 bytes or raw string; production: use KMS)
MASTER_KEY=dev-master-key-must-be-32-chars!!

# LLM (optional for local dev — fake embeddings used when OPENAI_API_KEY unset)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=

# Stripe (optional — billing + Pro gating for agents / optimizer)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
# Redirect URLs after Checkout (defaults work for local web /billing)
BILLING_SUCCESS_URL=http://localhost:3000/billing?success=1
BILLING_CANCEL_URL=http://localhost:3000/billing?canceled=1

# Next.js (browser). On Vercel, set these in Project → Settings → Environment Variables, then redeploy.
NEXT_PUBLIC_API_URL=http://localhost:8000
# Stripe publishable key (pk_test_… or pk_live_…) — safe in the browser; set in Vercel for production
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Clerk (Next.js auth UI — add paths /sign-in and /sign-up in Clerk Dashboard → Paths)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

